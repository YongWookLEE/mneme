# Mneme 환경 변수 템플릿
# 사용법: `cp deploy/.env.example deploy/.env` → 필수 값 채우기
# 절대 git에 커밋하지 말 것 (.gitignore 등록됨)

# ─── 외부 노출 URL ─────────────────────────────────────────────
# 로컬 개발: http://localhost:8080
# 운영: https://mneme.example.com
MNEME_BASE_URL=http://localhost:8080
MNEME_FRONTEND_ORIGIN=http://localhost:5173

# ─── 데이터베이스 ───────────────────────────────────────────────
MNEME_DB_URL=jdbc:postgresql://postgres:5432/mneme
MNEME_DB_USER=mneme
MNEME_DB_PASSWORD=change-me-with-strong-random

# ─── Google OAuth (필수) ───────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials에서 발급
# Authorized redirect URI에 ${MNEME_BASE_URL}/oauth/google/callback 등록
MNEME_GOOGLE_OAUTH_CLIENT_ID=
MNEME_GOOGLE_OAUTH_CLIENT_SECRET=

# ─── OpenAI (필수) ─────────────────────────────────────────────
# https://platform.openai.com/api-keys 에서 발급
# Usage limits에서 월 예산 상한 설정 권장
MNEME_OPENAI_API_KEY=
MNEME_OPENAI_EMBED_MODEL=text-embedding-3-small
MNEME_OPENAI_LLM_MODEL=gpt-4o-mini

# ─── Rate Limit ────────────────────────────────────────────────
MNEME_RATE_LIMIT_PER_MIN=60
MNEME_RATE_LIMIT_PER_DAY=5000
MNEME_RATE_LIMIT_WRITE_PER_MIN=20

# ─── 토큰 사용량 한도 (사용자별 일일) ──────────────────────────
MNEME_TOKEN_LIMIT_EMBED_PER_DAY=100000
MNEME_TOKEN_LIMIT_LLM_PER_DAY=50000

# ─── 세션/토큰 TTL ─────────────────────────────────────────────
MNEME_SESSION_TTL_HOURS=168
MNEME_OAUTH_ACCESS_TOKEN_TTL_MIN=30
MNEME_OAUTH_REFRESH_TOKEN_TTL_DAYS=30
# MNEME_SESSION_COOKIE_DOMAIN=

# ─── 이메일 (선택) ─────────────────────────────────────────────
# `none`이면 로그만 출력 (개발 기본)
# `sendgrid` / `ses` / `resend` 등 어댑터 추가 시 확장
MNEME_EMAIL_PROVIDER=none
MNEME_EMAIL_API_KEY=
MNEME_EMAIL_FROM=noreply@example.com
# 임계치 알림 수신자 (콤마 구분)
MNEME_ADMIN_EMAILS=

# ─── 백업 (선택, 운영 권장) ────────────────────────────────────
# Backblaze B2 또는 S3 호환 스토리지
# MNEME_BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
# MNEME_BACKUP_S3_BUCKET=mneme-backups
# MNEME_BACKUP_S3_ACCESS_KEY=
# MNEME_BACKUP_S3_SECRET_KEY=

# ─── Spring / JVM ──────────────────────────────────────────────
# 로컬: local, 운영: prod
SPRING_PROFILES_ACTIVE=local
JAVA_OPTS=-Xmx1g
